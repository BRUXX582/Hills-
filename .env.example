# Example environment file - Copy to .env and fill in your values

# GitHub Configuration
GITHUB_TOKEN=your_github_token_here
GITHUB_REPOSITORY=BRUXX582/Hills-

# AI Model Selection
# Options: gpt-4, claude, llama
AI_MODEL=gpt-4

# OpenAI API (for GPT-4)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic API (for Claude)
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Ollama (for local Llama)
# Default: http://localhost:11434 (when running locally)
LLAMA_API_URL=http://localhost:11434

# Model Parameters
MAX_TOKENS=1000
TEMPERATURE=0.7

# Feature Toggles
ENABLE_PR_REVIEW=true
ENABLE_ISSUE_RESPONSE=true
ENABLE_DISCUSSION_RESPONSE=true
MAX_CODE_CONTEXT_LINES=100

# Webhook Configuration (for self-hosted server)
WEBHOOK_SECRET=your-webhook-secret-here
